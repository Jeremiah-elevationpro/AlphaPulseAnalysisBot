[Unit]
Description=AlphaPulse XAUUSD Trading Bot
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/alphapulse
ExecStart=/home/ubuntu/alphapulse/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
EnvironmentFile=/home/ubuntu/alphapulse/.env

[Install]
WantedBy=multi-user.target
